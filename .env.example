# 이 파일을 복사해서 ".env" 로 만들고 값을 채우세요.
#   (Windows PowerShell)  Copy-Item .env.example .env
# .env 는 절대 공유하지 마세요. 로그인 세션·키가 담깁니다.

# ── 네이버 로그인 쿠키 (README 의 '쿠키 얻는 법' 참고) ──
NID_AUT=여기에_NID_AUT_값_붙여넣기
NID_SES=여기에_NID_SES_값_붙여넣기

# ── 리버힐 카페 설정 ──
CAFE_CLUB_ID=31185658
CAFE_MENU_ID=0

# ── 나(사용자) 정보 ──
MY_NAME=김홍구
MY_PART=3

# ── 감지 설정 ──
KEYWORDS=배치표,추가,변동,휴무,취소,대기,스페어,3부,근무
NOTIFY_MODE=keyword
POLL_INTERVAL_MS=90000

# ── 서버 ──
PORT=3000
CONTACT_EMAIL=you@example.com

# ── 웹푸시 VAPID 키: `npm run gen-vapid` 실행하면 자동으로 아래에 추가됨 ──
# VAPID_PUBLIC_KEY=...
# VAPID_PRIVATE_KEY=...
